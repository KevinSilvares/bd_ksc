    "    print(\"Conexión establecida.\")\n",
    "    print(f\"Tienes {len(buckets['Buckets'])} buckets en tu cuenta.\")\n",
    "except Exception as e:\n",
    "    print(\"Error de conexión.\")\n",
    "    print(e)"
   ]
